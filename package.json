{
	"name": "@waynevanson/unplugin-cargo",
	"version": "4.0.0",
	"description": "Import wasm-bindgen compatible Rust to JavaScript via unplugin",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./vite": {
			"types": "./dist/vite.d.ts",
			"default": "./dist/vite.js"
		},
		"./rollup": {
			"types": "./dist/rollup.d.ts",
			"default": "./dist/rollup.js"
		},
		"./webpack": {
			"types": "./dist/webpack.d.ts",
			"default": "./dist/webpack.js"
		},
		"./esbuild": {
			"types": "./dist/esbuild.d.ts",
			"default": "./dist/esbuild.js"
		},
		"./rspack": {
			"types": "./dist/rspack.d.ts",
			"default": "./dist/rspack.js"
		}
	},
	"type": "module",
	"repository": {
		"url": "https://github.com/waynevanson/unplugin-cargo"
	},
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/"
	},
	"files": [
		"dist"
	],
	"keywords": [
		"unplugin",
		"vite-plugin",
		"rollup-plugin",
		"webpack-plugin",
		"esbuild-plugin",
		"rspack-plugin",
		"rust",
		"cargo",
		"wasm",
		"webassembly",
		"wasm-bindgen"
	],
	"scripts": {
		"build": "tsup",
		"pretest": "tsup",
		"test": "vitest run",
		"prepublishOnly": "tsup"
	},
	"author": "Wayne Van Son",
	"license": "MIT",
	"packageManager": "pnpm@10.27.0",
	"devDependencies": {
		"@biomejs/biome": "^2.3.13",
		"@farmfe/core": "^1.7.11",
		"@playwright/test": "^1.61.0",
		"@rollup/plugin-node-resolve": "^16.0.0",
		"@rollup/plugin-wasm": "^6.2.2",
		"@rspack/cli": "^2.0.8",
		"@rspack/core": "^2.0.8",
		"@rspack/plugin-html": "^0.5.8",
		"@types/node": "^24.10.9",
		"@types/picomatch": "^3.0.0",
		"@vitest/coverage-v8": "4.0.18",
		"esbuild": "^0.28.1",
		"esbuild-plugin-pino": "^2.3.3",
		"html-webpack-plugin": "^5.6.7",
		"pino-pretty": "^13.1.3",
		"rolldown": "^1.1.1",
		"rollup": "^4.57.1",
		"sirv": "^3.0.2",
		"tsup": "^8.0.0",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vite-plugin-wasm": "^3.5.0",
		"vitest": "^4.0.18",
		"webpack": "^5.107.2",
		"webpack-cli": "^7.0.3"
	},
	"dependencies": {
		"node-object-hash": "^3.1.1",
		"picomatch": "^4.0.0",
		"pino": "^10.3.0",
		"unplugin": "^2.0.0",
		"valibot": "^1.2.0"
	}
}
